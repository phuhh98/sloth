{
  "name": "@sloth/cli",
  "version": "0.0.1",
  "private": true,
  "description": "sloth CLI wrapper for Go binary distribution",
  "license": "ISC",
  "type": "module",
  "bin": {
    "sloth": "bin/sloth.js"
  },
  "files": [
    "bin",
    "dist/bin",

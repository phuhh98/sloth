        <mxCell id="77KPwD5JUIfZxNA-zf42-29" parent="77KPwD5JUIfZxNA-zf42-27" style="text;strokeColor=none;fillColor=none;spacingLeft=4;spacingRight=4;overflow=hidden;rotatable=0;points=[[0,0.5],[1,0.5]];portConstraint=eastwest;fontSize=12;whiteSpace=wrap;html=1;" value="&lt;div&gt;&lt;b&gt;name&lt;/b&gt;: string&lt;/div&gt;&lt;div&gt;&lt;br&gt;&lt;/div&gt;&lt;div&gt;&lt;b&gt;label&lt;/b&gt;: string&lt;/div&gt;&lt;div&gt;&lt;br&gt;&lt;/div&gt;&lt;div&gt;&lt;b&gt;route&lt;/b&gt;: path string&lt;/div&gt;&lt;div&gt;&lt;br&gt;&lt;/div&gt;&lt;b&gt;dataset&lt;/b&gt;: [{&lt;blockquote style=&quot;margin: 0 0 0 40px; border: none; padding: 0px;&quot;&gt;&lt;div&gt;// array map to any content data in side strapi cms&lt;/div&gt;&lt;div&gt;&lt;b&gt;key&lt;/b&gt;: string unique&lt;/div&gt;&lt;div&gt;&lt;b&gt;contentType&lt;/b&gt;: contentType&#39;s key&lt;/div&gt;&lt;/blockquote&gt;&lt;div&gt;}]&lt;/div&gt;&lt;div&gt;&lt;br&gt;&lt;/div&gt;&lt;div&gt;puckConfig: JSON&lt;/div&gt;" vertex="1">
